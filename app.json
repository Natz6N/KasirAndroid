{
  "expo": {
    "name": "Omah Krupuk",
    "slug": "omah-krupuk-pos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.jpg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#6366F1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.jpg",
        "backgroundColor": "#6366F1"
      },
      "package": "com.omahhkrupuk.pos",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Omah Krupuk to access camera for barcode scanning."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c976c8e6-dd2b-4045-a8b5-3f92bbeb8851"
      }
    }
  }
}
